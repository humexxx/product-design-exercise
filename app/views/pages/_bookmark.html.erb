<% post = bookmark.bookmarkable %>

<div class="list-group-item py-3">
  <div class="d-flex justify-content-between align-items-start gap-3">
    <div class="d-flex flex-column flex-shrink-0">
      <%# Simple move controls keep manual ordering explicit without the scope of drag-and-drop. %>
      <%= button_to move_up_post_bookmark_path(post), method: :patch, disabled: index.zero?, class: "btn btn-link text-muted p-0 lh-1 border-0", form_class: "d-inline" do %>
        <i class="bi bi-arrow-up-circle fs-6"></i>
        <span class="visually-hidden">Move <%= bookmark.display_name %> up</span>
      <% end %>

      <%= button_to move_down_post_bookmark_path(post), method: :patch, disabled: index == total_count - 1, class: "btn btn-link text-muted p-0 lh-1 border-0", form_class: "d-inline" do %>
        <i class="bi bi-arrow-down-circle fs-6"></i>
        <span class="visually-hidden">Move <%= bookmark.display_name %> down</span>
      <% end %>
    </div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-center gap-2">
        <%= link_to post, class: "text-decoration-none" do %>
          <div class="fw-semibold text-dark"><%= bookmark.display_name %></div>
        <% end %>

        <%= link_to edit_post_bookmark_path(post), data: { turbo_stream: true }, class: "btn btn-link text-muted p-0 lh-1", title: "Rename bookmark", aria: { label: "Rename bookmark #{bookmark.display_name}" } do %>
          <i class="bi bi-pencil-square"></i>
          <span class="visually-hidden">Rename bookmark <%= bookmark.display_name %></span>
        <% end %>
      </div>

      <% if bookmark.name.present? %>
        <div class="text-muted small mt-1">Original title: <%= post.title %></div>
      <% end %>

      <%= link_to post, class: "text-decoration-none d-block" do %>
        <div class="text-muted small mt-1"><%= truncate(post.body, length: 120) %></div>
        <small class="text-muted d-block mt-2">Saved <%= time_ago_in_words(bookmark.created_at) %> ago</small>
      <% end %>
    </div>

    <div class="d-flex flex-column align-items-end gap-2 flex-shrink-0">
      <%= button_to post_bookmark_path(post), method: :delete, class: "btn btn-link text-warning p-0", form_class: "d-inline" do %>
        <i class="bi bi-bookmark-fill fs-5"></i>
        <span class="visually-hidden">Remove bookmark for <%= post.title %></span>
      <% end %>
    </div>
  </div>
</div>
