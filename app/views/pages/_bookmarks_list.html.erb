<% if bookmarks.any? %>
  <hr class="my-5">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 text-muted fw-semibold">Bookmarked Posts</h5>
    <small class="text-muted"><%= pluralize(bookmarks.size, "bookmark") %></small>
  </div>

  <div class="list-group">
    <% bookmarks.each do |bookmark| %>
      <% post = bookmark.bookmarkable %>

      <div class="list-group-item py-3">
        <div class="d-flex justify-content-between align-items-start gap-3">
          <%= link_to post, class: "text-decoration-none flex-grow-1" do %>
            <div class="fw-semibold text-dark"><%= post.title %></div>
            <div class="text-muted small mt-1"><%= truncate(post.body, length: 120) %></div>
            <small class="text-muted d-block mt-2">Saved <%= time_ago_in_words(bookmark.created_at) %> ago</small>
          <% end %>

          <%= button_to post_bookmark_path(post), method: :delete, class: "btn btn-link text-warning p-0 flex-shrink-0", form_class: "d-inline" do %>
            <i class="bi bi-bookmark-fill fs-5"></i>
            <span class="visually-hidden">Remove bookmark for <%= post.title %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
