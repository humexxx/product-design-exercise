<% editing_bookmark ||= nil %>

<hr class="my-5">

<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="mb-0 text-muted fw-semibold">Bookmarked Posts</h5>
  <small class="text-muted"><%= pluralize(bookmarks.size, "bookmark") %></small>
</div>

<% if bookmarks.any? %>
  <div class="list-group">
    <% bookmarks.each_with_index do |bookmark, index| %>
      <% if editing_bookmark == bookmark %>
        <%= render "pages/bookmark_edit_form", bookmark: bookmark %>
      <% else %>
        <%= render "pages/bookmark", bookmark: bookmark, index: index, total_count: bookmarks.size %>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="border rounded-3 bg-body-tertiary px-4 py-4 text-center">
    <div class="fw-semibold text-dark mb-1">No bookmarks yet</div>
    <div class="text-muted small">Save a post from Recent Posts to build your list here.</div>
  </div>
<% end %>
