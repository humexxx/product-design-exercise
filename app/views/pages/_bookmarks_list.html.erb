<% editing_bookmark ||= nil %>

<% if bookmarks.any? %>
  <hr class="my-5">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 text-muted fw-semibold">Bookmarked Posts</h5>
    <small class="text-muted"><%= pluralize(bookmarks.size, "bookmark") %></small>
  </div>

  <div class="list-group">
    <% bookmarks.each_with_index do |bookmark, index| %>
      <% if editing_bookmark == bookmark %>
        <%= render "pages/bookmark_edit_form", bookmark: bookmark %>
      <% else %>
        <%= render "pages/bookmark", bookmark: bookmark, index: index, total_count: bookmarks.size %>
      <% end %>
    <% end %>
  </div>
<% end %>
